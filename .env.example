OPENROUTER_API_KEY=your_openrouter_api_key_here

# ntfy 설정
# Docker 배포 시 NTFY_SERVER_URL은 http://ntfy (내부 서비스명)으로 자동 설정됨
# 로컬 테스트 시 http://localhost:8080
NTFY_SERVER_URL=http://localhost:8080
NTFY_TOPIC=research-agent
# ntfy 외부 접근 URL (ntfy 서버가 사용하는 base URL, Reverse Proxy 뒤에 있을 경우 도메인 입력)
NTFY_BASE_URL=http://localhost:8080
# 자체 호스팅 ntfy 인증 (ntfy-init.sh로 생성한 유저)
NTFY_USER=admin
NTFY_PASS=changeme

RESEARCH_TOPIC=Efficient Transformer Attention for Long Sequences
RESEARCHER_NAME=lee

# 선택사항
# Semantic Scholar API 키 (없으면 익명으로 요청 — 전체 사용자 공유 1000 RPS, 폭주 시 추가 스로틀링 가능)
# API 키 발급 시 인증 요청으로 전환 — 초기 한도 1 RPS (안정적)
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
